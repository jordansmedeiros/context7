# ============================================================
# Context7 MCP Server - Variaveis de ambiente para Cloudron
# Copie para .env.cloudron e preencha os valores
# ============================================================

# --- OBRIGATORIO ---
# API Key do Context7 (formato: ctx7sk...)
CONTEXT7_API_KEY=

# --- RECOMENDADO (producao) ---
# Chave AES-256 para encriptar IPs de clientes (64 caracteres hex)
# Gerar com: openssl rand -hex 32
CLIENT_IP_ENCRYPTION_KEY=

# --- OPCIONAIS (tem defaults) ---
# URL base da API Context7 (default: https://context7.com/api)
# CONTEXT7_API_URL=

# URL do servidor MCP de recursos (default: https://mcp.context7.com)
# RESOURCE_URL=

# URL do servidor de autenticacao (default: https://context7.com)
# AUTH_SERVER_URL=

# Proxy HTTPS (se necessario)
# HTTPS_PROXY=

# Certificado CA customizado (se necessario)
# NODE_EXTRA_CA_CERTS=
